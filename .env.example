# HTTP transport port (ignored by the stdio transport).
PORT=3000

# Optional. A GitHub token raises the API rate limit for the repo tools from
# 60 requests/hour (unauthenticated) to 5,000/hour. Any token with public
# read access works — no special scopes needed. The server runs fine without it.
GITHUB_TOKEN=

# Optional override, for pointing the blog tools at a local/staging blog.
# BLOG_BASE_URL=http://localhost:3000
