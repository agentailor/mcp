{
  "name": "@agentailor/mcp",
  "version": "0.2.0",
  "description": "MCP server for Agentailor — search the blog and read articles and open-source repo docs over the Model Context Protocol.",
  "type": "module",
  "license": "Apache-2.0",
  "main": "dist/index.stdio.js",
  "bin": {
    "agentailor-mcp": "dist/index.stdio.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "agentailor",
    "fastmcp",
    "ai",
    "llm"
  ],
  "homepage": "https://github.com/agentailor/mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentailor/mcp.git"
  },
  "bugs": {
    "url": "https://github.com/agentailor/mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm run build",
    "dev:stdio": "tsx watch src/index.stdio.ts",
    "dev:http": "tsx watch src/index.http.ts",
    "start:stdio": "node dist/index.stdio.js",
    "start:http": "node dist/index.http.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "inspect": "mcp-inspector http://localhost:3000/mcp",
    "inspect:stdio": "mcp-inspector --cli node dist/index.stdio.js --method tools/list"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "fastmcp": "^4.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.22.0",
    "@types/node": "^26.0.0",
    "prettier": "^3.9.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
