{
  "name": "agentailor-mcp",
  "version": "0.1.0",
  "description": "MCP server for Agentailor — search the blog and read articles and open-source repo docs over the Model Context Protocol.",
  "type": "module",
  "main": "dist/index.stdio.js",
  "scripts": {
    "build": "tsc",
    "dev:stdio": "tsx watch src/index.stdio.ts",
    "dev:http": "tsx watch src/index.http.ts",
    "start:stdio": "node dist/index.stdio.js",
    "start:http": "node dist/index.http.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "inspect": "mcp-inspector http://localhost:3000/mcp",
    "inspect:stdio": "mcp-inspector --cli node dist/index.stdio.js --method tools/list"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "fastmcp": "^4.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.22.0",
    "@types/node": "^26.0.0",
    "prettier": "^3.9.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
